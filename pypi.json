n_version":"py3","requires_python":">=3.6","size":34348,"upload_time":"2022-02-11T04:05:08","upload_time_iso_8601":"2022-02-11T04:05:08.435914Z","url":"https://files.pythonhosted.org/packages/72/56/23bc2cd54f1ac86c549fc2f9f9461b785f8fcd20af1aa72944eadc83d73f/binance_futures_connector-1.6.0-py3-none-any.whl","yanked":false,"yanked_reason":null},{"comment_text":"","digests":{"blake2b_256":"59b10a3a391ff1c667cc7fd69d44b7684050c0ec2cf1b586aa60ab41aed0c4cd","md5":"80ffa7578e5b6cee7b4d6ec944e726a3","sha256":"a2a3f4ec235e55fba06a9af73abd6807f328e7c62198a17b8f5ae6dc4d6c9eb3"},"downloads":-1,"filename":"binance-futures-connector-1.6.0.tar.gz","has_sig":false,"md5_digest":"80ffa7578e5b6cee7b4d6ec944e726a3","packagetype":"sdist","python_version":"source","requires_python":">=3.6","size":29227,"upload_time":"2022-02-11T04:05:10","upload_time_iso_8601":"2022-02-11T04:05:10.345294Z","url":"https://files.pythonhosted.org/packages/59/b1/0a3a391ff1c667cc7fd69d44b7684050c0ec2cf1b586aa60ab41aed0c4cd/binance-futures-connector-1.6.0.tar.gz","yanked":false,"yanked_reason":null}],"1.7.0":[{"comment_text":"","digests":{"blake2b_256":"ec926307d9e8428bb350ed92a562ba59f9694b37f97c1c7d40a2dfbc9ba41945","md5":"74bbcce31b05c6963e2b57bb54d48c68","sha256":"d3e8d8e0098188bbf7d973b639e2e7ce074de136ffd5c6f03bbc65ce88775108"},"downloads":-1,"filename":"binance_futures_connector-1.7.0-py3-none-any.whl","has_sig":false,"md5_digest":"74bbcce31b05c6963e2b57bb54d48c68","packagetype":"bdist_wheel","python_version":"py3","requires_python":">=3.6","size":34351,"upload_time":"2022-02-11T04:30:20","upload_time_iso_8601":"2022-02-11T04:30:20.001534Z","url":"https://files.pythonhosted.org/packages/ec/92/6307d9e8428bb350ed92a562ba59f9694b37f97c1c7d40a2dfbc9ba41945/binance_futures_connector-1.7.0-py3-none-any.whl","yanked":false,"yanked_reason":null},{"comment_text":"","digests":{"blake2b_256":"b656dc71fc4fcde5811e0f97b769a2d258c7643fe39634a5442b528b90d4dff8","md5":"9a266e8a9d17441f39e392a5cedb4bd3","sha256":"c9774